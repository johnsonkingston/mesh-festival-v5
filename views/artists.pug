doctype html
html(lang=language[0])
    include includes/head.pug
    script(src=baseURL+"static/script/artists.js")

    body.artists
        include includes/sitenav.pug
        //pre#debugLog(style="position:fixed;top:0;left:0;z-index:999;background:rgba(0,0,0,0.85);color:#0f0;font-size:12px;padding:1em;max-height:100vh;overflow:auto;")
            - if(events && events.length > 0)
                | events[0] fields (total: #{events.length})
                br
                - for(var k in events[0])
                    | #{k}: #{typeof events[0][k] === 'object' ? JSON.stringify(events[0][k]) : events[0][k]}
                    br
            - else
                | events array is empty
        - var char = ''
        - var nameBefore = ''
        - var n = 0
        - var formats = ['ausstellungen','screenings','diskurs','konferenz','performances','clubnights'];
        - var formatsTranslation = {ausstellungen: ['Ausstellungen','Exhibtions'], konferenz: ['Konferenz','Conference'],performances: ['Performances','Performances'],  diskurs: ['Talks & Panels','Talks & Panels'], screenings: ['Screenings','Screenings'], clubnights: ['Club Nights','Club Nights']};
        #filters 
            .bubble.active#filterAll(onclick="filterTimetableAll()",data-all='1')='All'
            each format in formats
                .bubble.filterpill(onclick="filterTimetable('"+format+"',$(this))",data-visible=1,id="filter-"+format)=formatsTranslation[format][languageParameter]

        //    .bubble.active#filtermap(onclick="$('#map').toggle();")='Map'
        //- #map 
        //-     img(src=imgURL+"5850ee5c-5b08-4fe4-ad9b-186dcf9044ab.png",onclick="$('#map').hide();")
            
        main

            each event in events 
                //if(char !== event.Name.substr(0,1).toUpperCase())
                    h3.char=event.Name.substr(0,1)
                a(href=baseURL+'events/'+event.slug+'/'+language[0],class=event.Format).artistLine
                    .artist
                        //.left
                        .middle
                            //a(href=baseURL+'events/'+event.slug+'/'+language[0],class=event.Format)
                            h3=event.First_Name+' '+event.Name
                            h4=event.Title
                        //.right 
                            a(href=baseURL+'events/'+event.slug+'/'+language[0],class=event.Format)
                                if(formatsTranslation[event.Format] !== undefined)
                                    h4.format=formatsTranslation[event.Format][languageParameter]
                                    if(event.Venues.length > 0)
                                        if(venues[event.Venues[0].Venues_id] !== undefined)
                                            h4.venue=venues[event.Venues[0].Venues_id].Name
                            if(events[n+1] !== undefined)        
                                a(href=baseURL+'events/'+events[n+1].slug+'/'+language[0],class=events[n+1].Format)    
                                    if(events[n+1].First_Name+events[n+1].Name == event.First_Name+event.Name)
                                        if(formatsTranslation[events[n+1].Format] !== undefined)
                                            h4.format=formatsTranslation[events[n+1].Format][languageParameter]
                                        if(events[n+1].Venues.length > 0)
                                            if(venues[events[n+1].Venues[0].Venues_id] !== undefined)
                                                h4.venue=venues[events[n+1].Venues[0].Venues_id].Name                                    

                                
                - char = event.Name.substr(0,1).toUpperCase()
                - nameBefore = (event.First_Name+event.Name)
                -n++

        include includes/footer.pug