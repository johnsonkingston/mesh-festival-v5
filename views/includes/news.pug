.marquee 
    - var newsCount = news.length-1
    p
        each val in [0,1,2]
            span= ' • '+news[newsCount].translations[languageParameter].Title
            - newsCount--;
        -newsCount = news.length-1
        each val in [0,1,2]
            span= ' • '+news[newsCount].translations[languageParameter].Title
            - newsCount--;
    .newscontent
        .newscontentInner.grid
            .grid-sizer

#newsClose(onclick='closeNews()')
    img(src=baseURL+'static/img/close.svg')




script.
    $('.marquee span').on('click',function(){
        closeNews();

        $('.newscontentInner').html('');

        $( news ).each(function( index ) {
            var newsarticle = '<div class="newsarticle grid-item"><h1>'+news[index].translations[languageParameter].Title+'</h1><div class="newsarticleContent">'+news[index].translations[languageParameter].Content+'</div></div>';
            $('.newscontentInner').prepend(newsarticle);
        });
        $( "video" ).each(function( index ) {
            $(this).attr('playsinline','true');
            $(this).attr('preload','metadata');
        });

        if($( window ).width() > $( window ).height()){
            $('.grid').masonry({
                itemSelector: '.grid-item',
                columnWidth: '.grid-item'
            });
        }


    });

    function closeNews(){
        $('.marquee').toggleClass('newsopen');
        $('#newsClose').toggle();
        $('#navButton').toggle();
    }


