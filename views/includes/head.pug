head 
include vars.pug
- var languageParameter = language[1];


- var imgURL = 'https://env-9468449.appengine.flow.ch/assets/';
    link(rel='stylesheet', type='text/css', href=baseURL+'static/styles/main.min.css')
    script(src="https://code.jquery.com/jquery-3.5.1.min.js" integrity="sha256-9/aliU8dGd2tb6OSsuzixeV4y/faTqgFtohetphbbj0=" crossorigin="anonymous")

    meta(name="viewport", content="width=device-width, user-scalable=no, minimum-scale=1.0, maximum-scale=1.0")

    if(data.id == 1 || data.id == 3)
        title Mesh – Festival für Kunst und Technologie – Münchenstein / Basel
    else if(data.translations[languageParameter] === undefined)
        title Mesh – Festival für Kunst und Technologie – #{data.title}
    else 
        title Mesh – Festival für Kunst und Technologie – #{data.translations[languageParameter].Title}

    if(data.id == 1 || data.id == 3)     
        meta(property="og:title" content="Mesh – Festival für Kunst und Technologie – 16.–20. Oktober 2024")
    else if(data.translations[languageParameter] === undefined)
        meta(property="og:title" content=data.title)
    else if(data.Artist == undefined)
        meta(property="og:title" content=data.translations[languageParameter].Title+' / Mesh – Festival für Kunst und Technologie')
    else 
        meta(property="og:title" content=data.Artist+': '+data.translations[languageParameter].Title)

    meta(name="description",content="Mesh – Festival für Kunst und Technologie – 16.–20. Oktober 2024")
    meta(property="og:description", content="Mesh – Festival für Kunst und Technologie – 16.–20. Oktober 2024: Multisensorische Erfahrungen, interaktive, immersive Erlebnisse und Installationen, Nachdenken über eine freundliche Zukunft")
    meta(property="og:type", content="website")
    meta(property="og:url", content="https://meshfestival.ch")
    if(data.Main_Image == null || data.id == 3)
        meta(property="og:image" content="/static/img/favicon/android-chrome-512x512.png")
    else
        meta(property="og:image" content=imgURL+data.Main_Image.filename_disk+'?key=icon')
    meta(property="og:site_name" content="Mesh – Festival für Kunst und Technologie")

    link(rel="apple-touch-icon",sizes="180x180",href="/static/img/favicon/android-chrome-192x192.png")
    link(rel="icon",type="image/png",sizes="32x32",href="/static/img/favicon/favicon-32x32.png")
    link(rel="icon",type="image/png",sizes="16x16",href="/static/img/favicon/favicon-16x16.png")
    link(rel="mask-icon",href="/static/img/favicon/favicon_23.png",color="#000")
    meta(name="msapplication-TileColor",content="#000")
    meta(name="theme-color",content="#fff")
    link(rel="icon",type="image/png",href="/static/img/favicon/android-chrome-192x192.png")
    meta(name="robots",content="max-image-preview:large")
    meta(name="google-site-verification", content="TNAoxn34J4XEOzd8PTJtXvliDdC8DqZFmlmGiJ4_IxQ")


    script.
        var baseURL = '!{baseURL}';
        var currentUrl = window.location.pathname;
        var languageParameter = !{languageParameter};
        if(currentUrl.substr(currentUrl.length - 3) == '/de'){
            currentUrl = currentUrl.replace('/de','');
        }

        data = !{JSON.stringify(data).replace(/<\//g, "<\\/")};
        //console.log('data object', data);
        navigation = !{JSON.stringify(navigation).replace(/<\//g, "<\\/")};
        //console.log('navigation object', navigation);
        footer = !{JSON.stringify(footer).replace(/<\//g, "<\\/")};
        //console.log('footer object', footer);
        language = !{JSON.stringify(language).replace(/<\//g, "<\\/")};
        //console.log('language object', language);
        highlights = !{JSON.stringify(highlights).replace(/<\//g, "<\\/")};
        //console.log('highlights object', highlights);
        events = !{JSON.stringify(events).replace(/<\//g, "<\\/")};
        //console.log('events object', events);
        venues = !{JSON.stringify(venues).replace(/<\//g, "<\\/")};
        //console.log('venues object', venues);
        format = !{JSON.stringify(format).replace(/<\//g, "<\\/")};
        //console.log('format object', format);        


        function dateformat(dateIn){
            var dateUnix = Date.parse(dateIn);
            return new Date(dateUnix).toLocaleDateString('en-us', { weekday:"long", year:"numeric", month:"short", day:"numeric"});
        }
         


