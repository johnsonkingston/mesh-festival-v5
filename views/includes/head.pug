- var imgURL = 'https://env-9468449.appengine.flow.ch/assets/';
    link(rel='stylesheet', type='text/css', href=baseURL+'static/styles/main.min.css')
    script(src="https://code.jquery.com/jquery-3.5.1.min.js" integrity="sha256-9/aliU8dGd2tb6OSsuzixeV4y/faTqgFtohetphbbj0=" crossorigin="anonymous")
    script(src="https://unpkg.com/masonry-layout@4/dist/masonry.pkgd.min.js" crossorigin="anonymous")
    script(src="https://embed.ticketpark.ch/v1/")
    meta(name="viewport", content="width=device-width, user-scalable=no, minimum-scale=1.0, maximum-scale=1.0")

    if(data.id == 1)     
        title Mesh – Festival für Kunst und Technologie – Münchenstein / Basel
    else if(data.translations[languageParameter] === undefined)
        title Mesh – Festival für Kunst und Technologie – #{data.title}
    else 
        title Mesh – Festival für Kunst und Technologie – #{data.translations[languageParameter].Title}

    if(data.id == 1)     
        meta(property="og:title" content="Mesh – Festival für Kunst und Technologie – 16.–20. Oktober 2024")

    else if(data.translations[languageParameter] === undefined)
        meta(property="og:title" content=data.title)
    else 
        meta(property="og:title" content=data.Artist+': '+data.translations[languageParameter].Title)

    meta(name="description",content="Mesh – Festival für Kunst und Technologie – 16.–20. Oktober 2024")
    meta(property="og:description", content="Multisensorische Erfahrungen, interaktive, immersive Erlebnisse und Installationen, Nachdenken über eine freundliche Zukunft")
    meta(property="og:type", content="website")
    meta(property="og:url", content="https://meshfestival.ch")
    if data.Main_Image == null
        meta(property="og:image" content="/static/img/favicon/android-chrome-512x512.png")
    else
        meta(property="og:image" content=imgURL+data.Main_Image.filename_disk+'?key=icon')
    meta(property="og:site_name" content="Mesh – Festival für Kunst und Technologie")

    link(rel="apple-touch-icon",sizes="180x180",href="/static/img/favicon/android-chrome-192x192.png")
    link(rel="icon",type="image/png",sizes="32x32",href="/static/img/favicon/favicon-32x32.png")
    link(rel="icon",type="image/png",sizes="16x16",href="/static/img/favicon/favicon-16x16.png")
    link(rel="mask-icon",href="/static/img/favicon/favicon_23.png",color="#000")
    meta(name="msapplication-TileColor",content="#000")
