nav
    a(href=baseURL)
        img#headerlogo.logo(src=baseURL+'static/img/mesh-festival1_top.png',loading="lazy")
    ul
        each val in navigation[languageParameter].Menu
            li.navigation
                a(href=baseURL+'pages/'+val.URL+'/'+language[0])= val.Title
              

        if(language[0] == 'de')
            li.navigation.navigationMobile
                a(href=baseURL+'timetable/de') Program
            li.navigation.navigationMobile
                a(href=baseURL+'artists/de') Artists 
        else 
            li.navigation.navigationMobile
                a(href=baseURL+'timetable/en') Programme
            li.navigation.navigationMobile
                a(href=baseURL+'artists/en') Artists   

        li.navigation.navigationMobile
            a(href=baseURL+'pages/visit/'+language[0]) Visit
        li.navigation.navigationMobile
            a(href=baseURL+'pages/about/'+language[0]) About

    .languages
        if(data.pathname == '' || data.pathname == '/' )
            li.smallpill
                a(href=baseURL+data.pathname+'de').
                    DE
            li.smallpill
                a(href=baseURL+data.pathname+'en').
                    EN   
        else
            li.smallpill
                a(href=baseURL+data.pathname+'/de').
                    DE
            li.smallpill
                a(href=baseURL+data.pathname+'/en').
                    EN    
    .navBottom 
        .left 
            if(language[0] == 'de')
                .navSub
                    a(href=baseURL+'timetable/de') Program
                .navSub
                    a(href=baseURL+'artists/de') Artists 
            else 
                .navSub
                    a(href=baseURL+'timetable/en') Programme
                .navSub
