    script.
        function toggleNav(){
            $('nav').toggleClass('open');
            $('#navButtonClose').toggle();
            $('#navButton').toggle();
        }
        $(window).keydown(function(){
            var x = event.keyCode;
            if (x == 27) {
                $('#navButtonClose').hide();
                $('#navButton').hide();
                $('nav').removeClass('open');
                closeNewsletter();
            }
        });
