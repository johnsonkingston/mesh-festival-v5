html(lang=language[0])
    include includes/head.pug
    body.startpage
        include includes/navigation.pug
        include includes/news.pug

        main
            - var n = 1
            - var z = -10
            each item in data.View
                section(id='section'+n)

                    if(language[0] == 'en' && item.Video_Id_En !== undefined)
                        video.videoDesk(id='video'+n,src=imgURL+item.Video_Id_En,muted='true',poster=imgURL+item.Video_Cover+'?key=icon',autoplay='true',loop='true',playsinline='true',preload="auto",)
                    else 
                        video.videoDesk(id='video'+n,src=imgURL+item.Video_Id,muted='true',poster=imgURL+item.Video_Cover+'?key=icon',autoplay='true',loop='true',playsinline='true',preload="auto",)

                    if(language[0] == 'en' && item.Video_Id_Mobile_En !== undefined)
                        if(item.Video_Id_Mobile !== undefined)
                            video.videoMobile(src=imgURL+item.Video_Id_Mobile_En,muted='true',poster=imgURL+item.Video_Cover_Mobile+'?key=icon',autoplay='true',loop='true',playsinline='true',preload="auto")
                        else
                            video.videoMobile(src=imgURL+item.Video_Id_En,muted='true',poster=imgURL+item.Video_Cover+'?key=icon',autoplay='true',loop='true',playsinline='true',preload="auto")
                    else 
                        if(item.Video_Id_Mobile !== undefined)
                            video.videoMobile(src=imgURL+item.Video_Id_Mobile,muted='true',poster=imgURL+item.Video_Cover_Mobile+'?key=icon',autoplay='true',loop='true',playsinline='true',preload="auto")
                        else
                            video.videoMobile(src=imgURL+item.Video_Id,muted='true',poster=imgURL+item.Video_Cover+'?key=icon',autoplay='true',loop='true',playsinline='true',preload="auto")
                   

                    if(item.Show_Title)
                        a(href=baseURL+'pages/'+item.Title_Link+'/'+language[0])
                            if(languageParameter == 0)
                                .bigpill= item.Title_De
                                a(href=baseURL+item.Caption_Link)
                                    .mainimageCaption= item.Caption_Desktop
                            else
                                .bigpill= item.Title_En
                                a(href=baseURL+item.Caption_Link)
                                    .mainimageCaption= item.Caption_Desktop
                    - n = n+1
                    - z = z+1
            script(src=baseURL+'static/script/startpage-scroll.js')
            
            <!-- Section 1 -->    
            .preview
                .left
                    h2=data.translations[languageParameter].Title
                    .
                        !{data.translations[languageParameter].Lead}
                .right 
                    .eventswrapper
                        each val in [0,1,2]
                            if(data.Events_1[val] !== undefined)
                                if(data.Events_1[val].Events_id.status == 'preview')
                                    a.eventLink
                                        .events
                                            - var caption =data.Events_1[val].Events_id.Artist
                                            .eventimg(style='background-image:url('+imgURL+data.Events_1[val].Events_id.Main_Image.filename_disk+')')
                                                img(src=baseURL+'static/img/grid.svg')
                                            .caption &bull; #{caption}
                                else 
                                    a(href=baseURL+'events/'+data.Events_1[val].Events_id.slug+'/'+language[0]).eventLink
                                        .events
                                            - var caption =data.Events_1[val].Events_id.Artist
                                            .eventimg(style='background-image:url('+imgURL+data.Events_1[val].Events_id.Main_Image.filename_disk+')')
                                                img(src=baseURL+'static/img/grid.svg')
                                            .caption &bull; #{caption}

                        .previewItem 
                            .smallpill
                                - var title =data.translations[languageParameter].Title
                                a(href=baseURL+'pages/'+data.Events_1_Link)
                                    if(language[0] == 'en' )
                                        .
                                            More #{title}
                                    else 
                                        .
                                            Mehr #{title}     
                            
                            

